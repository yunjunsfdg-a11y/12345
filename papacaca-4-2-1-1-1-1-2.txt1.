local currentTab = 0

local function switchTab(id)
	if currentTab == id then return end
	currentTab = id
	
	for i, data in pairs(tabs) do
		if i == id then
			TweenService:Create(data.btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(120, 95, 255), TextColor3 = Color3.fromRGB(255, 255, 255)}):Play()
			TweenService:Create(data.stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(170, 150, 255), Transparency = 0}):Play()
			
			contents[i].Visible = true
			contents[i].Position = UDim2.new(0, 0, 0, 25)
			TweenService:Create(contents[i], TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)}):Play()
		else
			TweenService:Create(data.btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {BackgroundColor3 = Color3.fromRGB(24, 22, 34), TextColor3 = Color3.fromRGB(135, 130, 155)}):Play()
			TweenService:Create(data.stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(52, 48, 72), Transparency = 0}):Play()
			contents[i].Visible = false
		end
	end
end

