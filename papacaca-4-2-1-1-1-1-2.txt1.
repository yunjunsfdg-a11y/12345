task.spawn(function()
	local sequence = {
		Color3.fromRGB(255, 75, 75),
		Color3.fromRGB(255, 145, 0),
		Color3.fromRGB(255, 215, 0),
		Color3.fromRGB(75, 255, 75),
		Color3.fromRGB(75, 145, 255),
		Color3.fromRGB(115, 75, 255),
		Color3.fromRGB(215, 75, 255),
		Color3.fromRGB(255, 255, 255)
	}
	local targetText = "파카허브 알림"
	local colorIndex = 1
	
	while uiActive do
		hubTitle.TextColor3 = sequence[colorIndex]
		hubTitle.TextTransparency = 0
		hubTitle.Text = ""
		
		for i = 1, #targetText do
			if not uiActive then break end
			hubTitle.Text = string.sub(targetText, 1, i)
			typeSfx:Play()
			task.wait(0.035)
		end
		
		if not uiActive then break end
		task.wait(6)
		
		if not uiActive then break end
		local fade = TweenService:Create(hubTitle, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = 1})
		fade:Play()
		fade.Completed:Wait()
		
		task.wait(0.2)
		colorIndex = colorIndex % #sequence + 1
	end
end)

