local function playClickEffect(button)
	sfx:Play()
	local originalSize = button.Size
	local shrinkSize = UDim2.new(originalSize.X.Scale, originalSize.X.Offset * 0.86, originalSize.Y.Scale, originalSize.Y.Offset * 0.86)
	
	TweenService:Create(button, TweenInfo.new(0.04, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = shrinkSize}):Play()
	task.wait(0.04)
	TweenService:Create(button, TweenInfo.new(0.14, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = originalSize}):Play()
end

local function createTab(name, layoutOrder, text)
	local btn = Instance.new("TextButton")
	btn.Name = name.."Tab"
	btn.Size = UDim2.new(0, 95, 1, 0)
	btn.BackgroundColor3 = Color3.fromRGB(24, 22, 34)
	btn.Text = text
	btn.TextColor3 = Color3.fromRGB(135, 130, 155)
	btn.TextSize = 12
	btn.Font = Enum.Font.GothamBold
	btn.LayoutOrder = layoutOrder
	btn.BackgroundTransparency = 1
	btn.TextTransparency = 1
	btn.Parent = tabContainer
	
	local bCorner = Instance.new("UICorner")
	bCorner.CornerRadius = UDim.new(0, 10)
	bCorner.Parent = btn
	
	local bStroke = Instance.new("UIStroke")
	bStroke.Thickness = 1
	bStroke.Color = Color3.fromRGB(52, 48, 72)
	bStroke.Transparency = 1
	bStroke.Parent = btn

	local cFrame = Instance.new("Frame")
	cFrame.Name = name.."Content"
	cFrame.Size = UDim2.new(1, 0, 1, 0)
	cFrame.Position = UDim2.new(0, 0, 0, 30)
	cFrame.BackgroundTransparency = 1
	cFrame.Visible = false
	cFrame.Parent = contentArea
	
	tabs[layoutOrder] = {btn = btn, stroke = bStroke}
	contents[layoutOrder] = cFrame
	
	btn.MouseEnter:Connect(function()
		if btn.TextColor3 ~= Color3.fromRGB(255, 255, 255) then
			TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(195, 190, 215)}):Play()
		end
	end)
	
	btn.MouseLeave:Connect(function()
		if btn.TextColor3 ~= Color3.fromRGB(255, 255, 255) then
			TweenService:Create(btn, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(135, 130, 155)}):Play()
		end
	end)
	
	return btn, cFrame
end

