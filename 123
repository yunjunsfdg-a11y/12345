local function fireButtonSignal(btn)
    if not btn or not btn.Active or not btn.Visible then return end
    local success = false
    
    if getconnections then
        local events = { btn.MouseButton1Click, btn.MouseButton1Down, btn.Activated }
        for _, event in ipairs(events) do
            for _, connection in ipairs(getconnections(event)) do
                connection:Fire()
                success = true
            end
        end
    end

    if not success then
        local pos = btn.AbsolutePosition
        local size = btn.AbsoluteSize
        local x = pos.X + (size.X / 2)
        local y = pos.Y + (size.Y / 2)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
        task.wait(0.05)
        VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
    end
end

